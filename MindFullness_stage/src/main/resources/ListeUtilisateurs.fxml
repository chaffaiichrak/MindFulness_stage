<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.ListeUtilisateursController"
      style="-fx-background-color:#F0F4F8;" spacing="0">

    <!-- ═══════════════ EN-TÊTE PAGE ═══════════════ -->
    <HBox style="-fx-padding:20 28 14 28;" alignment="CENTER_LEFT" spacing="0">
        <VBox HBox.hgrow="ALWAYS" spacing="3">
            <Label text="Gestion des Utilisateurs" styleClass="section-title"/>
            <Label text="Recherchez, filtrez, triez et exportez vos comptes" styleClass="section-subtitle"/>
        </VBox>
        <Button text="＋  Nouvel utilisateur" styleClass="btn-add-primary" onAction="#handleAjouter"/>
    </HBox>

    <!-- ═══════════════ BARRE FILTRES + OUTILS ═══════════════ -->
    <HBox style="-fx-padding:0 28 14 28; -fx-background-color:#F0F4F8;" spacing="10" alignment="CENTER_LEFT">

        <!-- Recherche -->
        <TextField fx:id="searchField"
                   promptText="🔍  Rechercher par nom, email..."
                   styleClass="search-box"
                   onKeyReleased="#handleSearch"
                   HBox.hgrow="ALWAYS"
                   style="-fx-max-width:300;"/>

        <!-- Filtre rôle -->
        <ComboBox fx:id="filterRole" styleClass="form-combo"
                  style="-fx-pref-width:155;" promptText="Rôle"/>

        <!-- Filtre statut -->
        <ComboBox fx:id="filterStatut" styleClass="form-combo"
                  style="-fx-pref-width:120;" promptText="Statut"/>

        <!-- Tri -->
        <ComboBox fx:id="sortCombo" styleClass="form-combo"
                  style="-fx-pref-width:155;" promptText="Trier par"/>

        <!-- Réinitialiser -->
        <Button text="↺  Réinitialiser" styleClass="btn-filter" onAction="#handleResetFilters">
            <tooltip><Tooltip text="Effacer tous les filtres"/></tooltip>
        </Button>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- Export CSV -->
        <Button text="📊  CSV" styleClass="btn-export-csv" onAction="#handleExportCSV">
            <tooltip><Tooltip text="Exporter en CSV (Excel)"/></tooltip>
        </Button>

        <!-- Export PDF -->
        <Button text="📄  PDF" styleClass="btn-export-pdf" onAction="#handleExportPDF">
            <tooltip><Tooltip text="Exporter en PDF (via navigateur)"/></tooltip>
        </Button>
    </HBox>

    <!-- ═══════════════ TABLE CARD ═══════════════ -->
    <VBox style="-fx-padding:0 28 0 28;" VBox.vgrow="ALWAYS" spacing="0">
        <VBox styleClass="table-card" VBox.vgrow="ALWAYS" spacing="0">

            <!-- En-tête tableau -->
            <HBox styleClass="table-card-header" alignment="CENTER_LEFT" spacing="0">
                <HBox spacing="8" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                    <Label text="Liste des utilisateurs" styleClass="table-card-title"/>
                    <Label fx:id="countLabel" text="(0 utilisateurs)"
                           style="-fx-text-fill:#95A3B0; -fx-font-size:12px;"/>
                </HBox>
            </HBox>

            <!-- TableView -->
            <TableView fx:id="usersTable" styleClass="custom-table"
                       VBox.vgrow="ALWAYS" fixedCellSize="52">
                <columns>
                    <TableColumn fx:id="colPhoto"   text="Photo"     prefWidth="64"/>
                    <TableColumn fx:id="colPrenom"  text="Prénom"    prefWidth="120"/>
                    <TableColumn fx:id="colNom"     text="Nom"       prefWidth="120"/>
                    <TableColumn fx:id="colEmail"   text="Email"     prefWidth="200"/>
                    <TableColumn fx:id="colTel"     text="Téléphone" prefWidth="115"/>
                    <TableColumn fx:id="colRole"    text="Rôle"      prefWidth="120"/>
                    <TableColumn fx:id="colStatut"  text="Statut"    prefWidth="90"/>
                    <TableColumn fx:id="colActions" text="Actions"   prefWidth="185"/>
                </columns>
                <placeholder>
                    <VBox alignment="CENTER" spacing="12" style="-fx-padding:50;">
                        <Label text="Aucun utilisateur trouvé" styleClass="empty-text"/>
                        <Label text="Modifiez vos critères de recherche"
                               style="-fx-text-fill:#CBD5E1; -fx-font-size:12px;"/>
                    </VBox>
                </placeholder>
            </TableView>

            <!-- PAGINATION -->
            <HBox styleClass="pagination-box" alignment="CENTER" spacing="6">
                <Label fx:id="pageInfoLabel" text="Page 1 / 1" styleClass="page-info-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox fx:id="paginationBox" spacing="4" alignment="CENTER"/>
            </HBox>

        </VBox>
    </VBox>

    <Region style="-fx-pref-height:20; -fx-min-height:20;"/>
</VBox>
