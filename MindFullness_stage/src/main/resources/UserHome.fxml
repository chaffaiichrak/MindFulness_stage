<?xml version="1.0" encoding="UTF-8"?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>

<!--
    UserHome.fxml — MindFullnessFront Office v3
    - Avatar rond (Circle clip en Java)
    - Navbar cliquable avec scroll-to-section
    - 5 services : Locaux Psychiatries, Tests Psychologiques, Resources, Evenements, Reclamations
    - 6 membres equipe en 2 rangées de 3, avec photos depuis resources/equipe/
    - Boutons Facebook / Instagram par membre
    - Profil : navigate dans la même fenêtre (pas de popup)
-->
<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="controllers.UserHomeController"
           prefWidth="1200" prefHeight="720"
           style="-fx-background-color:#F0F4F8;">

    <!-- Cercles décoratifs fond -->
    <StackPane mouseTransparent="true">
        <Circle radius="360" fill="rgba(27,67,50,0.04)"
                StackPane.alignment="TOP_LEFT" translateX="-130" translateY="-90"/>
        <Circle radius="260" fill="rgba(123,94,167,0.04)"
                StackPane.alignment="BOTTOM_RIGHT" translateX="110" translateY="90"/>
        <Circle radius="170" fill="rgba(27,67,50,0.03)"
                StackPane.alignment="TOP_RIGHT" translateX="-60" translateY="130"/>
    </StackPane>

    <!-- ═══════════════════════════ LAYOUT PRINCIPAL ═══════════════════════════ -->
    <VBox spacing="0" StackPane.alignment="TOP_CENTER">

        <!-- ══════════════════════════════ NAVBAR ══════════════════════════════ -->
        <HBox fx:id="navbar" alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color:#1B4332;
                     -fx-border-color:#2D6A4F; -fx-border-width:0 0 1.5 0;
                     -fx-padding:0 36 0 36;
                     -fx-min-height:66; -fx-pref-height:66;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.22),14,0,0,4);">

            <!-- Logo -->
            <HBox alignment="CENTER_LEFT" spacing="11">
                <ImageView fitWidth="36" fitHeight="36" preserveRatio="true">
                    <image><Image url="@logo.png" backgroundLoading="true"/></image>
                </ImageView>
                <VBox spacing="0" alignment="CENTER_LEFT">
                    <HBox spacing="0">
                        <Label fx:id="brandLabel" text="Mind"
                               style="-fx-text-fill:#FFFFFF; -fx-font-size:21px;
                                      -fx-font-weight:900; -fx-font-family:'Georgia';"/>
                        <Label text="Aura"
                               style="-fx-text-fill:#BBF7D0; -fx-font-size:21px;
                                      -fx-font-weight:900; -fx-font-family:'Georgia';"/>
                    </HBox>
                    <Label text="PSYCHOLOGIE &amp; BIEN-ETRE"
                           style="-fx-text-fill:rgba(187,247,208,0.75); -fx-font-size:7px; -fx-font-weight:800;"/>
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Liens navbar — tous avec fx:id pour scroll et highlight -->
            <HBox spacing="28" alignment="CENTER" style="-fx-padding:0 32 0 0;">
                <Label fx:id="navAccueil" text="Accueil"
                       onMouseClicked="#scrollToAccueil"
                       style="-fx-text-fill:#FFFFFF; -fx-font-size:13px; -fx-font-weight:700;
                              -fx-cursor:hand; -fx-border-color:#BBF7D0;
                              -fx-border-width:0 0 2 0; -fx-padding:4 2 4 2;"/>
                <Label fx:id="navServices" text="Services"
                       onMouseClicked="#scrollToServices"
                       style="-fx-text-fill:rgba(187,247,208,0.8); -fx-font-size:13px;
                              -fx-font-weight:600; -fx-cursor:hand; -fx-padding:4 2 4 2;"/>
                <Label fx:id="navEquipe" text="Equipe"
                       onMouseClicked="#scrollToEquipe"
                       style="-fx-text-fill:rgba(187,247,208,0.8); -fx-font-size:13px;
                              -fx-font-weight:600; -fx-cursor:hand; -fx-padding:4 2 4 2;"/>
                <Label fx:id="navContact" text="Contact"
                       onMouseClicked="#scrollToContact"
                       style="-fx-text-fill:rgba(187,247,208,0.8); -fx-font-size:13px;
                              -fx-font-weight:600; -fx-cursor:hand; -fx-padding:4 2 4 2;"/>
            </HBox>

            <!-- Bouton session -->
            <StackPane fx:id="sessionBtn" onMouseClicked="#toggleDropdown"
                       style="-fx-cursor:hand;">
                <HBox fx:id="sessionHBox" alignment="CENTER" spacing="9"
                      style="-fx-background-color:rgba(255,255,255,0.12);
                             -fx-background-radius:30;
                             -fx-border-color:rgba(187,247,208,0.4); -fx-border-radius:30; -fx-border-width:1.5;
                             -fx-padding:6 14 6 8;">

                    <!-- Avatar : StackPane contenant un ImageView circulaire -->
                    <StackPane>
                        <!-- ImageView circulaire via clip appliqué en Java -->
                        <ImageView fx:id="avatarImage"
                                   fitWidth="38" fitHeight="38"
                                   preserveRatio="false" visible="false"/>
                        <Label fx:id="avatarInitials" text="?"
                               style="-fx-text-fill:#FFFFFF; -fx-font-weight:900; -fx-font-size:14px;"/>
                    </StackPane>

                    <VBox spacing="1" alignment="CENTER_LEFT">
                        <Label fx:id="sessionName" text="Utilisateur"
                               style="-fx-text-fill:#FFFFFF; -fx-font-size:12.5px;
                                      -fx-font-weight:700; -fx-max-width:130;"/>
                        <Label fx:id="sessionRole" text=""
                               style="-fx-text-fill:#BBF7D0; -fx-font-size:10px; -fx-font-weight:600;"/>
                    </VBox>

                    <Label text="&#9660;"
                           style="-fx-text-fill:#BBF7D0; -fx-font-size:9px; -fx-padding:0 0 0 2;"/>
                </HBox>
            </StackPane>

        </HBox>

        <!-- ══════════════════════════ ZONE SCROLLABLE ══════════════════════════ -->
        <ScrollPane fx:id="mainScroll"
                    fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    VBox.vgrow="ALWAYS"
                    style="-fx-background-color:transparent; -fx-background:transparent;
                           -fx-border-color:transparent;">
            <VBox spacing="0" style="-fx-background-color:transparent;">

                <!-- ════════════════ SECTION HERO / CITATION ════════════════ -->
                <VBox fx:id="sectionAccueil" alignment="CENTER" spacing="24"
                      style="-fx-padding:60 80 52 80;
                             -fx-background-color:linear-gradient(to bottom,
                               rgba(27,67,50,0.05), rgba(240,244,248,1));
                             -fx-border-color:#E2E8F0; -fx-border-width:0 0 1.5 0;">

                    <HBox alignment="CENTER">
                        <Label text="CITATION DU MOMENT"
                               style="-fx-text-fill:#7B5EA7; -fx-font-size:10px; -fx-font-weight:800;
                                      -fx-background-color:#EDE9FE; -fx-background-radius:20;
                                      -fx-padding:5 18 5 18;
                                      -fx-border-color:#DDD6FE; -fx-border-radius:20; -fx-border-width:1;"/>
                    </HBox>

                    <Label fx:id="quoteText"
                           text="&#10077;  La sante mentale est une priorite, pas un luxe.  &#10078;"
                           wrapText="true" textAlignment="CENTER"
                           style="-fx-text-fill:#1A1A2E; -fx-font-size:21px; -fx-font-style:italic;
                                  -fx-font-family:'Georgia'; -fx-max-width:800; -fx-line-spacing:6;"/>

                    <Label fx:id="quoteAuthor" text="&#8212; MindFullness"
                           style="-fx-text-fill:#1B4332; -fx-font-size:13px; -fx-font-weight:700;"/>

                    <HBox alignment="CENTER" spacing="10">
                        <Region style="-fx-background-color:#BBF7D0;
                                       -fx-pref-width:80; -fx-pref-height:1.5;"/>
                        <Region style="-fx-background-color:#BBF7D0;
                                       -fx-pref-width:80; -fx-pref-height:1.5;"/>
                    </HBox>

                    <!-- Carte bienvenue -->
                    <VBox alignment="CENTER" spacing="10"
                          style="-fx-background-color:#FFFFFF; -fx-background-radius:18;
                                 -fx-border-color:#E2E8F0; -fx-border-radius:18; -fx-border-width:1.5;
                                 -fx-padding:24 52 24 52; -fx-max-width:540;
                                 -fx-effect:dropshadow(gaussian,rgba(27,67,50,0.08),14,0,0,4);">
                        <Label text="Votre espace personnel MindFullness"
                               style="-fx-text-fill:#5A6475; -fx-font-size:11px; -fx-font-weight:700;"/>
                        <Label fx:id="welcomeLabel" text="Bienvenue !"
                               style="-fx-text-fill:#1A1A2E; -fx-font-size:27px;
                                      -fx-font-weight:900; -fx-font-family:'Georgia';"/>
                        <Label fx:id="roleLabel" text=""
                               style="-fx-text-fill:#7B5EA7; -fx-font-size:11.5px; -fx-font-weight:700;
                                      -fx-background-color:#EDE9FE; -fx-background-radius:12;
                                      -fx-padding:4 18 4 18;
                                      -fx-border-color:#DDD6FE; -fx-border-radius:12; -fx-border-width:1;"/>
                    </VBox>
                </VBox>

                <!-- ══════════════════ SECTION SERVICES ══════════════════ -->
                <VBox fx:id="sectionServices" alignment="CENTER" spacing="36"
                      style="-fx-padding:60 60 60 60; -fx-background-color:transparent;">

                    <VBox alignment="CENTER" spacing="8">
                        <Label text="NOS SERVICES"
                               style="-fx-text-fill:#1B4332; -fx-font-size:10px; -fx-font-weight:800;"/>
                        <Label text="Explorez nos domaines d'expertise"
                               style="-fx-text-fill:#1A1A2E; -fx-font-size:28px;
                                      -fx-font-weight:900; -fx-font-family:'Georgia';"/>
                        <Label text="Des solutions adaptees a chaque besoin de sante mentale"
                               style="-fx-text-fill:#5A6475; -fx-font-size:14px;"/>
                    </VBox>

                    <!-- 5 cards services -->
                    <HBox spacing="18" alignment="CENTER">

                        <!-- 1 — Locaux Psychiatries -->
                        <VBox spacing="14" alignment="TOP_CENTER"
                              onMouseClicked="#goLocaux"
                              style="-fx-background-color:#FFFFFF; -fx-background-radius:18;
                                     -fx-border-color:#E2E8F0; -fx-border-radius:18; -fx-border-width:1.5;
                                     -fx-padding:28 20 22 20; -fx-pref-width:210; -fx-min-width:190;
                                     -fx-effect:dropshadow(gaussian,rgba(27,67,50,0.07),14,0,0,3);
                                     -fx-cursor:hand;">
                            <StackPane style="-fx-background-color:#F0FFF4; -fx-background-radius:16;
                                             -fx-min-width:56; -fx-min-height:56;
                                             -fx-pref-width:56; -fx-pref-height:56;"
                                       StackPane.alignment="CENTER">
                                <Label text="L" style="-fx-text-fill:#1B4332; -fx-font-size:24px;
                                               -fx-font-weight:900; -fx-font-family:'Georgia';"/>
                            </StackPane>
                            <Label text="Locaux"
                                   style="-fx-text-fill:#1B4332; -fx-font-size:9px; -fx-font-weight:800;
                                          -fx-background-color:#D1FAE5; -fx-background-radius:10;
                                          -fx-padding:3 10 3 10;"/>
                            <Label text="Locaux Psychiatries"
                                   wrapText="true" textAlignment="CENTER"
                                   style="-fx-text-fill:#1A1A2E; -fx-font-size:15px;
                                          -fx-font-weight:900; -fx-font-family:'Georgia';
                                          -fx-max-width:170;"/>
                            <Label text="Trouvez les centres psychiatriques et cliniques agrees pres de chez vous."
                                   wrapText="true" textAlignment="CENTER"
                                   style="-fx-text-fill:#5A6475; -fx-font-size:11px;
                                          -fx-line-spacing:3; -fx-max-width:170;"/>
                            <Region VBox.vgrow="ALWAYS"/>
                            <Button text="Acceder"
                                    onAction="#goLocaux"
                                    style="-fx-background-color:#1B4332; -fx-text-fill:#FFFFFF;
                                           -fx-font-size:11.5px; -fx-font-weight:700;
                                           -fx-background-radius:10; -fx-padding:8 0 8 0;
                                           -fx-cursor:hand; -fx-pref-width:9999; -fx-border-color:transparent;"/>
                        </VBox>

                        <!-- 2 — Tests Psychologiques -->
                        <VBox spacing="14" alignment="TOP_CENTER"
                              onMouseClicked="#goTests"
                              style="-fx-background-color:#1B4332; -fx-background-radius:18;
                                     -fx-border-color:#2D6A4F; -fx-border-radius:18; -fx-border-width:2;
                                     -fx-padding:28 20 22 20; -fx-pref-width:210; -fx-min-width:190;
                                     -fx-effect:dropshadow(gaussian,rgba(27,67,50,0.35),22,0,0,8);
                                     -fx-cursor:hand;">
                            <StackPane style="-fx-background-color:rgba(255,255,255,0.12);
                                             -fx-background-radius:16;
                                             -fx-min-width:56; -fx-min-height:56;
                                             -fx-pref-width:56; -fx-pref-height:56;"
                                       StackPane.alignment="CENTER">
                                <Label text="T" style="-fx-text-fill:#FFFFFF; -fx-font-size:24px;
                                               -fx-font-weight:900; -fx-font-family:'Georgia';"/>
                            </StackPane>
                            <Label text="Populaire"
                                   style="-fx-text-fill:#D4A843; -fx-font-size:9px; -fx-font-weight:800;
                                          -fx-background-color:rgba(212,168,67,0.15);
                                          -fx-background-radius:10; -fx-padding:3 10 3 10;
                                          -fx-border-color:rgba(212,168,67,0.4);
                                          -fx-border-radius:10; -fx-border-width:1;"/>
                            <Label text="Tests Psychologiques"
                                   wrapText="true" textAlignment="CENTER"
                                   style="-fx-text-fill:#FFFFFF; -fx-font-size:15px;
                                          -fx-font-weight:900; -fx-font-family:'Georgia';
                                          -fx-max-width:170;"/>
                            <Label text="Evaluez votre sante mentale avec nos tests valides scientifiquement."
                                   wrapText="true" textAlignment="CENTER"
                                   style="-fx-text-fill:rgba(255,255,255,0.75); -fx-font-size:11px;
                                          -fx-line-spacing:3; -fx-max-width:170;"/>
                            <Region VBox.vgrow="ALWAYS"/>
                            <Button text="Acceder"
                                    onAction="#goTests"
                                    style="-fx-background-color:#FFFFFF; -fx-text-fill:#1B4332;
                                           -fx-font-size:11.5px; -fx-font-weight:800;
                                           -fx-background-radius:10; -fx-padding:8 0 8 0;
                                           -fx-cursor:hand; -fx-pref-width:9999; -fx-border-color:transparent;"/>
                        </VBox>

                        <!-- FIN — seuls Locaux et Tests sont conservés -->
                    </HBox>

                    <!-- Stats -->
                    <HBox spacing="0" alignment="CENTER"
                          style="-fx-background-color:#FFFFFF; -fx-background-radius:16;
                                 -fx-border-color:#E2E8F0; -fx-border-radius:16; -fx-border-width:1.5;
                                 -fx-padding:26 0 26 0; -fx-max-width:860;
                                 -fx-effect:dropshadow(gaussian,rgba(27,67,50,0.06),12,0,0,2);">
                        <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="500+"
                                   style="-fx-text-fill:#1B4332; -fx-font-size:30px;
                                          -fx-font-weight:900; -fx-font-family:'Georgia';"/>
                            <Label text="Patients accompagnes"
                                   style="-fx-text-fill:#5A6475; -fx-font-size:12px; -fx-font-weight:600;"/>
                        </VBox>
                        <Region style="-fx-background-color:#E2E8F0; -fx-pref-width:1; -fx-pref-height:44;"/>
                        <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="98%"
                                   style="-fx-text-fill:#7B5EA7; -fx-font-size:30px;
                                          -fx-font-weight:900; -fx-font-family:'Georgia';"/>
                            <Label text="Taux de satisfaction"
                                   style="-fx-text-fill:#5A6475; -fx-font-size:12px; -fx-font-weight:600;"/>
                        </VBox>
                        <Region style="-fx-background-color:#E2E8F0; -fx-pref-width:1; -fx-pref-height:44;"/>
                        <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="15"
                                   style="-fx-text-fill:#1B4332; -fx-font-size:30px;
                                          -fx-font-weight:900; -fx-font-family:'Georgia';"/>
                            <Label text="Specialistes certifies"
                                   style="-fx-text-fill:#5A6475; -fx-font-size:12px; -fx-font-weight:600;"/>
                        </VBox>
                        <Region style="-fx-background-color:#E2E8F0; -fx-pref-width:1; -fx-pref-height:44;"/>
                        <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="24/7"
                                   style="-fx-text-fill:#7B5EA7; -fx-font-size:30px;
                                          -fx-font-weight:900; -fx-font-family:'Georgia';"/>
                            <Label text="Support disponible"
                                   style="-fx-text-fill:#5A6475; -fx-font-size:12px; -fx-font-weight:600;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- ══════════════════════ SECTION EQUIPE ══════════════════════ -->
                <VBox fx:id="sectionEquipe" alignment="CENTER" spacing="36"
                      style="-fx-padding:60 60 60 60;
                             -fx-background-color:rgba(27,67,50,0.025);
                             -fx-border-color:#E2E8F0; -fx-border-width:1.5 0 1.5 0;">

                    <VBox alignment="CENTER" spacing="8">
                        <Label text="NOTRE EQUIPE"
                               style="-fx-text-fill:#1B4332; -fx-font-size:10px; -fx-font-weight:800;"/>
                        <Label text="Des experts devoues a votre epanouissement"
                               style="-fx-text-fill:#1A1A2E; -fx-font-size:28px;
                                      -fx-font-weight:900; -fx-font-family:'Georgia';"/>
                        <Label text="Une equipe pluridisciplinaire qui vous accompagne avec bienveillance"
                               style="-fx-text-fill:#5A6475; -fx-font-size:13px;"/>
                    </VBox>

                    <!-- Équipe — 2 membres -->
                    <HBox spacing="24" alignment="CENTER">

                        <!-- Membre 1 — Wajed -->
                        <VBox spacing="0" alignment="CENTER"
                              style="-fx-background-color:#FFFFFF; -fx-background-radius:18;
                                     -fx-border-color:#E2E8F0; -fx-border-radius:18; -fx-border-width:1.5;
                                     -fx-pref-width:340; -fx-min-width:340; -fx-max-width:340;
                                     -fx-effect:dropshadow(gaussian,rgba(27,67,50,0.07),14,0,0,3);">

                            <!-- Conteneur d'image avec coins supérieurs arrondis -->
                            <StackPane fx:id="avatarM1"
                                       style="-fx-background-color:linear-gradient(to bottom right,#2D6A4F,#1B4332);
                                              -fx-background-radius:16 16 0 0;
                                              -fx-min-width:340; -fx-min-height:200;
                                              -fx-pref-width:340; -fx-pref-height:200;
                                              -fx-max-width:340; -fx-max-height:200;
                                              -fx-border-color:transparent; -fx-border-width:0;">

                                <!-- ImageView -->
                                <ImageView fx:id="imgM1"
                                           fitWidth="340" fitHeight="200"
                                           preserveRatio="false"
                                           visible="false"/>
                            </StackPane>

                            <!-- Contenu texte sous la photo -->
                            <VBox spacing="12" alignment="CENTER"
                                  style="-fx-padding:24 22 24 22; -fx-background-color:#FFFFFF;">

                                <!-- Nom et titre -->
                                <VBox spacing="4" alignment="CENTER">
                                    <Label text="Chaffai Ichrak"
                                           style="-fx-text-fill:#1A1A2E; -fx-font-size:18px;
                                                  -fx-font-weight:800; -fx-font-family:'Georgia';"/>
                                    <Label text="Coach de Vie"
                                           style="-fx-text-fill:#1B4332; -fx-font-size:13px;
                                                  -fx-font-weight:700; -fx-background-color:#D1FAE5;
                                                  -fx-background-radius:12; -fx-padding:4 14 4 14;"/>
                                </VBox>

                                <!-- Description -->
                                <Label text="Accompagne au quotidien vers un mieux-etre durable et un developpement personnel equilibre."
                                       wrapText="true" textAlignment="CENTER"
                                       style="-fx-text-fill:#5A6475; -fx-font-size:12px;
                                              -fx-line-spacing:4; -fx-max-width:290;"/>

                                <!-- Boutons réseaux sociaux -->
                                <HBox spacing="12" alignment="CENTER" style="-fx-padding:8 0 0 0;">
                                    <Button text="Facebook"
                                            style="-fx-background-color:#1877F2; -fx-text-fill:#FFFFFF;
                                                   -fx-font-size:11px; -fx-font-weight:700;
                                                   -fx-background-radius:20; -fx-padding:8 20 8 20;
                                                   -fx-cursor:hand; -fx-border-color:transparent;"/>
                                    <Button text="Instagram"
                                            style="-fx-background-color:linear-gradient(to bottom right,#833AB4,#E1306C);
                                                   -fx-text-fill:#FFFFFF; -fx-font-size:11px; -fx-font-weight:700;
                                                   -fx-background-radius:20; -fx-padding:8 20 8 20;
                                                   -fx-cursor:hand; -fx-border-color:transparent;"/>
                                </HBox>
                            </VBox>
                        </VBox>

                        <!-- Membre 2 — Chaffai Ichrak -->
                        <VBox spacing="0" alignment="CENTER"
                              style="-fx-background-color:#FFFFFF; -fx-background-radius:18;
                                     -fx-border-color:#E2E8F0; -fx-border-radius:18; -fx-border-width:1.5;
                                     -fx-pref-width:340; -fx-min-width:340; -fx-max-width:340;
                                     -fx-effect:dropshadow(gaussian,rgba(27,67,50,0.07),14,0,0,3);">

                            <StackPane fx:id="avatarM2"
                                       style="-fx-background-color:linear-gradient(to bottom right,#D4A843,#B8860B);
                                              -fx-background-radius:16 16 0 0;
                                              -fx-min-width:340; -fx-min-height:200;
                                              -fx-pref-width:340; -fx-pref-height:200;
                                              -fx-max-width:340; -fx-max-height:200;">
                                <ImageView fx:id="imgM2" fitWidth="340" fitHeight="200"
                                           preserveRatio="false" visible="false"/>
                            </StackPane>

                            <VBox spacing="12" alignment="CENTER"
                                  style="-fx-padding:24 22 24 22; -fx-background-color:#FFFFFF;">
                                <VBox spacing="4" alignment="CENTER">
                                    <Label text="Wajed Ouled Abdallah"
                                           style="-fx-text-fill:#1A1A2E; -fx-font-size:18px;
                                                  -fx-font-weight:800; -fx-font-family:'Georgia';"/>
                                    <Label text="Psychiatre &amp; Fondateur"
                                           style="-fx-text-fill:#D4A843; -fx-font-size:13px;
                                                  -fx-font-weight:700; -fx-background-color:#FEF9C3;
                                                  -fx-background-radius:12; -fx-padding:4 14 4 14;"/>
                                </VBox>

                                <Label text="Pionnier de la santé mentale en Tunisie, fondateur de MindFullness."
                                       wrapText="true" textAlignment="CENTER"
                                       style="-fx-text-fill:#5A6475; -fx-font-size:12px;
                                              -fx-line-spacing:4; -fx-max-width:290;"/>

                                <HBox spacing="12" alignment="CENTER" style="-fx-padding:8 0 0 0;">
                                    <Button text="Facebook"
                                            style="-fx-background-color:#1877F2; -fx-text-fill:#FFFFFF;
                                                   -fx-font-size:11px; -fx-font-weight:700;
                                                   -fx-background-radius:20; -fx-padding:8 20 8 20;
                                                   -fx-cursor:hand; -fx-border-color:transparent;"/>
                                    <Button text="Instagram"
                                            style="-fx-background-color:linear-gradient(to bottom right,#833AB4,#E1306C);
                                                   -fx-text-fill:#FFFFFF; -fx-font-size:11px; -fx-font-weight:700;
                                                   -fx-background-radius:20; -fx-padding:8 20 8 20;
