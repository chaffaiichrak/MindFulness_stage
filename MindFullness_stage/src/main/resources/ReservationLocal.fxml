<?xml version="1.0" encoding="UTF-8"?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>

<!--
    ReservationLocal.fxml — MindAura Front Office
    Formulaire de reservation pour un local psychiatrique selectionne.
-->
<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="controllers.ReservationLocalController"
           prefWidth="1200" prefHeight="720"
           style="-fx-background-color:#F0F4F8;">

    <StackPane mouseTransparent="true">
        <Circle radius="360" fill="rgba(27,67,50,0.04)"
                StackPane.alignment="TOP_LEFT" translateX="-130" translateY="-90"/>
        <Circle radius="260" fill="rgba(123,94,167,0.04)"
                StackPane.alignment="BOTTOM_RIGHT" translateX="110" translateY="90"/>
    </StackPane>

    <VBox spacing="0" StackPane.alignment="TOP_CENTER">

        <!-- ══════════════════════════════ NAVBAR ══════════════════════════════ -->
        <HBox fx:id="navbar" alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color:#1B4332;
                     -fx-border-color:#2D6A4F; -fx-border-width:0 0 1.5 0;
                     -fx-padding:0 36 0 36;
                     -fx-min-height:66; -fx-pref-height:66;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.22),14,0,0,4);">

            <Button onAction="#goBackToLocaux"
                    style="-fx-background-color:rgba(255,255,255,0.12); -fx-text-fill:#FFFFFF;
                           -fx-font-size:12px; -fx-font-weight:700; -fx-background-radius:20;
                           -fx-padding:7 16 7 14; -fx-cursor:hand; -fx-border-color:rgba(187,247,208,0.4);
                           -fx-border-radius:20; -fx-border-width:1;">
                <graphic>
                    <HBox spacing="6" alignment="CENTER">
                        <FontIcon iconLiteral="fas-arrow-left" iconSize="12" iconColor="#BBF7D0"/>
                        <Label text="Locaux" style="-fx-text-fill:#FFFFFF; -fx-font-size:12px; -fx-font-weight:700;"/>
                    </HBox>
                </graphic>
            </Button>

            <HBox alignment="CENTER_LEFT" spacing="9">
                <ImageView fitWidth="30" fitHeight="30" preserveRatio="true">
                    <image><Image url="@logo.png" backgroundLoading="true"/></image>
                </ImageView>
                <HBox spacing="0">
                    <Label text="Mind" style="-fx-text-fill:#FFFFFF; -fx-font-size:18px; -fx-font-weight:900; -fx-font-family:'Georgia';"/>
                    <Label text="Aura" style="-fx-text-fill:#BBF7D0; -fx-font-size:18px; -fx-font-weight:900; -fx-font-family:'Georgia';"/>
                </HBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>
            <Label text="RESERVATION" style="-fx-text-fill:#BBF7D0; -fx-font-size:11px; -fx-font-weight:800;"/>
        </HBox>

        <!-- ══════════════════════════ ZONE SCROLLABLE ══════════════════════════ -->
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    VBox.vgrow="ALWAYS"
                    style="-fx-background-color:transparent; -fx-background:transparent; -fx-border-color:transparent;">
            <VBox alignment="TOP_CENTER" spacing="0">

                <VBox alignment="CENTER" spacing="8"
                      style="-fx-padding:40 60 26 60;">
                    <Label text="RESERVER UN LOCAL" style="-fx-text-fill:#1B4332; -fx-font-size:10px; -fx-font-weight:800;
                           -fx-background-color:#D1FAE5; -fx-background-radius:20; -fx-padding:5 18 5 18;"/>
                    <Label text="Finalisez votre reservation"
                           style="-fx-text-fill:#1A1A2E; -fx-font-size:27px; -fx-font-weight:900; -fx-font-family:'Georgia';"/>
                    <Label text="Renseignez les informations ci-dessous, votre demande sera confirmee rapidement"
                           style="-fx-text-fill:#5A6475; -fx-font-size:13px;"/>
                </VBox>

                <HBox alignment="TOP_CENTER" spacing="26" style="-fx-padding:0 60 60 60;">

                    <!-- ══════════════ CARTE RECAPITULATIF DU LOCAL ══════════════ -->
                    <VBox fx:id="localSummaryCard" spacing="0" style="-fx-pref-width:360; -fx-min-width:360;
                          -fx-background-color:#FFFFFF; -fx-background-radius:18;
                          -fx-border-color:#E2E8F0; -fx-border-radius:18; -fx-border-width:1.5;
                          -fx-effect:dropshadow(gaussian,rgba(27,67,50,0.09),16,0,0,4);">

                        <StackPane fx:id="localImagePane" style="-fx-background-color:linear-gradient(to bottom right,#2D6A4F,#1B4332);
                                   -fx-background-radius:16 16 0 0; -fx-min-height:190; -fx-pref-height:190; -fx-max-height:190;">
                            <ImageView fx:id="localImageView" fitWidth="360" fitHeight="190" preserveRatio="false" visible="false"/>
                            <Label fx:id="localTypeBadge" text="Type"
                                   StackPane.alignment="TOP_LEFT"
                                   style="-fx-background-color:rgba(255,255,255,0.92); -fx-text-fill:#1B4332;
                                          -fx-font-size:10px; -fx-font-weight:800; -fx-background-radius:20; -fx-padding:5 12 5 12;">
                                <StackPane.margin><Insets top="12" left="12"/></StackPane.margin>
                            </Label>
                        </StackPane>

                        <VBox spacing="12" style="-fx-padding:22 22 24 22;">
                            <Label fx:id="localNomLabel" text="Nom du local" wrapText="true"
                                   style="-fx-text-fill:#1A1A2E; -fx-font-size:18px; -fx-font-weight:900; -fx-font-family:'Georgia';"/>

                            <HBox spacing="6" alignment="CENTER_LEFT">
                                <FontIcon iconLiteral="fas-map-marker-alt" iconSize="12" iconColor="#7B5EA7"/>
                                <Label fx:id="localAdresseLabel" text="Adresse" wrapText="true"
                                       style="-fx-text-fill:#5A6475; -fx-font-size:12px; -fx-font-weight:600; -fx-max-width:280;"/>
                            </HBox>

                            <HBox spacing="18">
                                <HBox spacing="5" alignment="CENTER_LEFT">
                                    <FontIcon iconLiteral="fas-users" iconSize="12" iconColor="#1B4332"/>
                                    <Label fx:id="localCapaciteLabel" text="0 places"
                                           style="-fx-text-fill:#1A1A2E; -fx-font-size:11.5px; -fx-font-weight:700;"/>
                                </HBox>
                                <HBox spacing="5" alignment="CENTER_LEFT">
                                    <FontIcon iconLiteral="fas-phone" iconSize="12" iconColor="#1B4332"/>
                                    <Label fx:id="localTelLabel" text="00 000 000"
                                           style="-fx-text-fill:#1A1A2E; -fx-font-size:11.5px; -fx-font-weight:700;"/>
                                </HBox>
                            </HBox>

                            <Label fx:id="localDescriptionLabel" text="Description"
                                   wrapText="true" style="-fx-text-fill:#5A6475; -fx-font-size:11.5px; -fx-line-spacing:3;"/>

                            <Region style="-fx-background-color:#E2E8F0; -fx-pref-height:1;"/>

                            <VBox spacing="6" style="-fx-background-color:#F0FFF4; -fx-background-radius:12; -fx-padding:14 16 14 16;">
                                <Label text="TARIF INDICATIF" style="-fx-text-fill:#1B4332; -fx-font-size:9.5px; -fx-font-weight:800;"/>
                                <Label fx:id="localTarifLabel" text="90 DT / heure"
                                       style="-fx-text-fill:#1B4332; -fx-font-size:16px; -fx-font-weight:900;"/>
                            </VBox>
                        </VBox>
                    </VBox>

                    <!-- ══════════════════════ FORMULAIRE ══════════════════════ -->
                    <VBox spacing="20" style="-fx-pref-width:520; -fx-min-width:460;
                          -fx-background-color:#FFFFFF; -fx-background-radius:18;
                          -fx-border-color:#E2E8F0; -fx-border-radius:18; -fx-border-width:1.5;
                          -fx-padding:30 32 30 32;
                          -fx-effect:dropshadow(gaussian,rgba(27,67,50,0.09),16,0,0,4);">

                        <Label text="Details de la reservation"
                               style="-fx-text-fill:#1A1A2E; -fx-font-size:18px; -fx-font-weight:900; -fx-font-family:'Georgia';"/>

                        <HBox spacing="16">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="Date de reservation *" style="-fx-text-fill:#1A1A2E; -fx-font-size:12px; -fx-font-weight:700;"/>
                                <DatePicker fx:id="datePicker" style="-fx-pref-width:9999; -fx-background-radius:10;"/>
                            </VBox>
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="Motif de la reservation *" style="-fx-text-fill:#1A1A2E; -fx-font-size:12px; -fx-font-weight:700;"/>
                                <ComboBox fx:id="motifCombo" style="-fx-pref-width:9999; -fx-background-radius:10;"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="16">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="Heure de debut *" style="-fx-text-fill:#1A1A2E; -fx-font-size:12px; -fx-font-weight:700;"/>
                                <ComboBox fx:id="heureDebutCombo" style="-fx-pref-width:9999; -fx-background-radius:10;"/>
                            </VBox>
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="Heure de fin *" style="-fx-text-fill:#1A1A2E; -fx-font-size:12px; -fx-font-weight:700;"/>
                                <ComboBox fx:id="heureFinCombo" style="-fx-pref-width:9999; -fx-background-radius:10;"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="16">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="Nom *" style="-fx-text-fill:#1A1A2E; -fx-font-size:12px; -fx-font-weight:700;"/>
                                <TextField fx:id="nomField" promptText="Votre nom" style="-fx-background-radius:10;"/>
                            </VBox>
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="Prenom *" style="-fx-text-fill:#1A1A2E; -fx-font-size:12px; -fx-font-weight:700;"/>
                                <TextField fx:id="prenomField" promptText="Votre prenom" style="-fx-background-radius:10;"/>
                            </VBox>
                        </HBox>

                        <Label fx:id="errorLabel" text="" wrapText="true" visible="false" managed="false"
                               style="-fx-text-fill:#B91C1C; -fx-font-size:12px; -fx-font-weight:700;
                                      -fx-background-color:#FEE2E2; -fx-background-radius:10; -fx-padding:10 14 10 14;"/>

                        <Region style="-fx-background-color:#E2E8F0; -fx-pref-height:1;"/>

                        <HBox alignment="CENTER_LEFT" spacing="10"
                              style="-fx-background-color:#EDE9FE; -fx-background-radius:12; -fx-padding:14 18 14 18;">
                            <VBox HBox.hgrow="ALWAYS">
                                <Label text="MONTANT ESTIME" style="-fx-text-fill:#7B5EA7; -fx-font-size:9.5px; -fx-font-weight:800;"/>
                                <Label fx:id="montantLabel" text="0 DT"
                                       style="-fx-text-fill:#1A1A2E; -fx-font-size:22px; -fx-font-weight:900; -fx-font-family:'Georgia';"/>
                            </VBox>
                            <Label fx:id="dureeLabel" text="0 h"
                                   style="-fx-text-fill:#7B5EA7; -fx-font-size:13px; -fx-font-weight:700;
                                          -fx-background-color:#FFFFFF; -fx-background-radius:20; -fx-padding:6 16 6 16;"/>
                        </HBox>

                        <HBox spacing="14" alignment="CENTER">
                            <Button text="Annuler" onAction="#goBackToLocaux"
                                    style="-fx-background-color:#F1F5F9; -fx-text-fill:#5A6475;
                                           -fx-font-size:13px; -fx-font-weight:700; -fx-background-radius:12;
                                           -fx-padding:12 0 12 0; -fx-cursor:hand; -fx-pref-width:160; -fx-border-color:transparent;"/>
                            <Button fx:id="confirmButton" text="Confirmer la reservation" onAction="#confirmerReservation"
                                    style="-fx-background-color:#1B4332; -fx-text-fill:#FFFFFF;
                                           -fx-font-size:13px; -fx-font-weight:800; -fx-background-radius:12;
                                           -fx-padding:12 0 12 0; -fx-cursor:hand; -fx-pref-width:9999; -fx-border-color:transparent;"/>
                        </HBox>
                    </VBox>
                </HBox>
            </VBox>
        </ScrollPane>
    </VBox>
</StackPane>
